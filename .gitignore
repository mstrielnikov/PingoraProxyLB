# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover / IntelliJ
.idea/
*.iml

# VS Code
.vscode/

# Logs and databases
*.log
*.sqlite
*.db

# Environment variables
.env
.env.*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# eBPF objects
*.bpf.o

# Credentials and certificates (protect sensitive test keys)
*.pem
*.crt
*.key
!examples/**/dummy.crt
!examples/**/dummy.key

# Cargo files
Cargo.lock
